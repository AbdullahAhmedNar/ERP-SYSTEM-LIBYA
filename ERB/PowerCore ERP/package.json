{
  "name": "powercore-erp",
  "version": "1.0.0",
  "description": "PowerCore ERP - نظام إدارة متكامل",
  "main": "dist-electron/main.js",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "node scripts/clean-release.js && node scripts/prepare-icon.js && vite build && electron-builder",
    "preview": "vite preview",
    "build:win": "node scripts/clean-release.js && node scripts/prepare-icon.js && vite build && electron-builder --win",
    "build:win:dir": "node scripts/clean-release.js && node scripts/prepare-icon.js && vite build && electron-builder --win --dir",
    "postinstall": "electron-builder install-app-deps",
    "prebuild": "node scripts/prepare-icon.js"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "date-fns": "^3.3.1",
    "html2pdf.js": "^0.14.0",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "react-to-print": "^2.15.1",
    "recharts": "^2.12.0",
    "uuid": "^9.0.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9",
    "postcss": "^8.4.35",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "to-ico": "^1.1.5",
    "typescript": "^5.2.2",
    "vite": "^5.1.4",
    "vite-plugin-electron": "^0.28.4",
    "wait-on": "^7.2.0"
  },
  "author": "PowerCore"
}
